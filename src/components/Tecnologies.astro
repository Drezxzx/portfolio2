---
import Css from "../icons/Css.astro";
import Html from "../icons/Html.astro";
import Js from "../icons/Js.astro";
import TypeScript from "../icons/TypeScript.astro";
import Php from "../icons/Php.astro";
import Sql from "../icons/Sql.astro";
import React from "../icons/React.astro";
import Tailwind from "../icons/Tailwind.astro";
import Node from "../icons/Node.astro";
import Python from "../icons/Python.astro";
---

<article class="flex flex-row w-full justify-around">
  <div class="flex flex-col gap-5">
    <Html class="size-16 hover:scale-110 transition" />
    <Python class="size-16 hover:scale-110 transition" />
    <Js class="size-16 hover:scale-110 transition" />
  </div>
  <div class="flex flex-col gap-5">
    <Css class="size-16 hover:scale-110 transition" />
    <Sql class="size-16 hover:scale-110 transition" />
    <Node class="size-16 hover:scale-110 transition" />
  </div>
  <div class="flex flex-col gap-5">
    <React class="size-16 hover:scale-110 transition" />
    <Tailwind class="size-16 hover:scale-110 transition" />
    <TypeScript class="size-16 hover:scale-110 transition" />
  </div>
</article>
